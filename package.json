{
  "name": "backend",
  "version": "1.0.0",
  "description": "Node.js TypeScript Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node -P tsconfig.server.json\" src/server.ts",
    "build": "tsc -p tsconfig.server.json",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "express": "^5.1.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.4",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
