{
  "info": {
    "_postman_id": "d7e8d16f-3d1b-42a7-bf47-bd18b49b9f4a",
    "name": "Sport Ecommerce Products API",
    "description": "Collection for auth + product CRUD + image upload testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "API Info",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Login (Admin/Staff)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.accessToken) {",
              "  pm.collectionVariables.set('accessToken', json.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"your_password\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Product (Admin/Staff)",
      "request": {
        "method": "POST",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "name",
              "value": "Nike Air Zoom",
              "type": "text"
            },
            {
              "key": "basePrice",
              "value": "129.99",
              "type": "text"
            },
            {
              "key": "categoryId",
              "value": "1",
              "type": "text"
            },
            {
              "key": "slug",
              "value": "nike-air-zoom",
              "type": "text"
            },
            {
              "key": "description",
              "value": "Lightweight running shoe.",
              "type": "text"
            },
            {
              "key": "image",
              "type": "file",
              "src": "/absolute/path/to/your-image.jpg"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update Product (Admin/Staff)",
      "request": {
        "method": "PUT",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "name",
              "value": "Nike Air Zoom 2",
              "type": "text"
            },
            {
              "key": "basePrice",
              "value": "139.99",
              "type": "text"
            },
            {
              "key": "isActive",
              "value": "true",
              "type": "text"
            },
            {
              "key": "image",
              "type": "file",
              "src": "/absolute/path/to/your-new-image.jpg"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{productId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Delete Product (Admin/Staff)",
      "request": {
        "method": "DELETE",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{productId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/products?page=1&limit=10&sort=newest",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "sort",
              "value": "newest"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Product Detail By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{productId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Product Detail By Slug",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/products/{{productSlug}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{productSlug}}"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "productSlug",
      "value": "nike-air-zoom"
    }
  ]
}
